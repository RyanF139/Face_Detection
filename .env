# =============================
# IDENTITAS SERVICE
# =============================

SERVICE_ID=capture_01
# ID service untuk identifikasi worker ini saat mengambil data CCTV dari server

CCTV_ENDPOINT=https://dashboard.smart-gateway.net/api/webhook/cctv
# URL API untuk mengambil daftar kamera CCTV

MODEL_PATH=models/face_detection_yunet_2023mar.onnx
# lokasi file model AI face detection (YuNet)


# =============================
# DETECTION CONFIG
# =============================

SCORE_THRESHOLD=0.8
# minimal confidence wajah dari model (0.0 - 1.0)
# semakin tinggi → semakin sedikit false detection

BLUR_THRESHOLD=0
# filter wajah blur menggunakan Laplacian variance
# 0 = tidak difilter
# contoh: 80 → wajah blur tidak akan disimpan


# =============================
# IMAGE STORAGE
# =============================

SAVE_FOLDER=image_face
# folder utama penyimpanan gambar

SAVE_INTERVAL=5
# interval minimal antar penyimpanan wajah (detik)

MAX_IMAGES=150
# maksimal jumlah gambar dalam folder
# jika lebih akan otomatis hapus yang paling lama


# =============================
# FRAME PROCESSING
# =============================

#RESIZE_WIDTH=640
RESIZE_WIDTH=640
# lebar maksimum frame yang dipakai untuk deteksi
# semakin kecil → semakin cepat CPU

RESIZE_HIGHT=360
# tinggi frame target (opsional untuk scaling preview)

MIN_SIZE_CAPTURE=5
# ukuran minimal wajah agar diproses
# wajah terlalu kecil akan diabaikan


# =============================
# FPS CONTROL
# =============================

FRAME_FPS=10
# FPS saat kamera aktif (ada wajah)

IDLE_FPS=10
# FPS saat tidak ada wajah
# bisa diturunkan untuk menghemat CPU

IDLE_TIMEOUT=10
# waktu tanpa deteksi wajah sebelum FPS turun ke IDLE_FPS


# =============================
# FACE CROP
# =============================

CROP_PADDING=0.35
# menambah area crop wajah (35% dari ukuran wajah)
# agar wajah tidak terlalu mepet


# =============================
# ANTI SPAM DETECTION
# =============================

FACE_COOLDOWN=8
# waktu minimal sebelum wajah pada area yang sama boleh disimpan lagi

FACE_MOVE_THRESHOLD=80
# minimal perpindahan posisi wajah (pixel)
# jika wajah tidak bergerak → tidak disimpan ulang

FACE_BUCKET_SIZE=220
# ukuran grid area wajah
# wajah dalam grid yang sama dianggap orang yang sama


# =============================
# CAMERA MANAGEMENT
# =============================

CAMERA_REFRESH_INTERVAL=60
# interval refresh daftar kamera dari API (detik)


# =============================
# WEBHOOK
# =============================

WEBHOOK_URL=https://dashboard.smart-gateway.net/api/webhook/detectionss
# endpoint webhook untuk mengirim hasil deteksi


# =============================
# DISPLAY PREVIEW
# =============================

ENABLE_VIEW=true
# menampilkan preview kamera dalam grid

DISPLAY_WIDTH=1200
# lebar window preview

DISPLAY_HEIGHT=800
# tinggi window preview


# =============================
# DEBUG MODE
# =============================

DEBUG_MODE=false
