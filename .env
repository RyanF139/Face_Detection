# 640x360 (16:9), 320x240 (4:3)
# ==============================
ENABLE_VIEW=true
#DISPLAY_WIDTH=320
#DISPLAY_HEIGHT=180
DISPLAY_WIDTH=1280
DISPLAY_HEIGHT=720


