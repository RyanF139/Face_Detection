SERVICE_ID=capture_03

MODEL_PATH=models/face_detection_yunet_2023mar.onnx
SCORE_THRESHOLD=0.9 # 0.0 - 1.0

SAVE_FOLDER=image_face
SAVE_INTERVAL= 8
MAX_IMAGES=150

# ==============================
# PROCESSING
# ==============================
ENABLE_RESIZE=false
RESIZE_WIDTH=640
RESIZE_HEIGHT=360
MIN_SIZE_CAPTURE=8

USE_GPU=true

# ==============================
# VIEW CONFIG 854x480 (16:9) , 1280x720 (16:9), 640x480 (4:3),
# 640x360 (16:9), 320x240 (4:3)
# ==============================
ENABLE_VIEW=true
#DISPLAY_WIDTH=320
#DISPLAY_HEIGHT=180
DISPLAY_WIDTH=1280
DISPLAY_HEIGHT=720


WEBHOOK_URL=https://dashboard.smart-gateway.net/api/webhook/detection
#WEBHOOK_URL= http://192.168.1.335:3001/webhook/detectionss
CCTV_ENDPOINT=https://dashboard.smart-gateway.net/api/webhook/cctv

CAMERA_REFRESH_INTERVAL=240 # dalam detik

WEBHOOK_TIMEOUT=5

DEBUG_MODE=true
DEBUG_VIDEO_DIR=./debug_videos
DEBUG_LOOP=true